# ─── Database (TiDB Cloud) ────────────────────────────────────────────────────
DB_HOST=gateway01.ap-northeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=your_tidb_username
DB_PASS=your_tidb_password
DB_NAME=fyp-db

# ─── App ──────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — do NOT set it on Railway
# For local dev, PORT defaults to 5000 if not set
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set this to your Netlify/Vercel URL in production
FRONTEND_URL=https://your-app.netlify.app
