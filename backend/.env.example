# ─── Database (TiDB Cloud) ────────────────────────────────────────────────────
DB_HOST=gateway01.ap-northeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=your_tidb_username
DB_PASS=your_tidb_password
DB_NAME=fyp-db

# ─── App ──────────────────────────────────────────────────────────────────────
# Render sets PORT automatically — do NOT hardcode it on Render
# For local dev, defaults to 8080 if not set
PORT=8080
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set this to your Cloudflare Pages URL in production
FRONTEND_URL=https://your-project.pages.dev
