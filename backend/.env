# ─── TalentBridge Backend — Environment Variables ─────────────────────────────
# LOCAL DEV: rename this file to .env  (it is already named .env in the repo)
# RAILWAY:   copy every key below into Railway → Variables panel (do NOT upload .env)
#
# ❗ NEVER commit real credentials to Git — .env is already in .gitignore

# ─── Database (TiDB Cloud) ────────────────────────────────────────────────────
# How to find these values:
#  1. TiDB Cloud → your cluster → "Connect" button (top-right)
#  2. Choose "General" connection type
#  3. Copy the values shown for host, port, user, password

DB_HOST=gateway01.ap-northeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=2Kz7qwuDcxMRtqr.root
# ↓ REPLACE this with the REAL password from TiDB Cloud "Connect" dialog
DB_PASS=YOUR_REAL_TIDB_PASSWORD_HERE
# ↓ Your database name — hyphens are fine as a connection param
DB_NAME=fyp-db

# ─── App ──────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — do NOT set PORT in Railway's Variables panel
# For local dev, use any free port (5000 avoids conflicts with AirPlay on Mac)
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set this to your exact Netlify URL (no trailing slash)
# Example: https://talentbridge-app.netlify.app
FRONTEND_URL=https://YOUR-SITE-NAME.netlify.app
